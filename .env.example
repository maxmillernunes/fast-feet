# API
PORT=3333

# Database
DATABASE_SCHEMA=public
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=fast-feet
POSTGRES_PORT=5432
# POSTGRES_HOST=postgres # DOCKER
POSTGRES_HOST=localhost # LOCAL

# Prisma
DATABASE_URL=postgresql://docker:docker@localhost:5432/fast-feet # LOCAL
# DATABASE_URL=postgresql://docker:docker@postgres:5432/fast-feet # DOCKER

# JWT
JWT_PRIVATE_
JWT_PUBLIC_

# AWS
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=fast-feet
AWS_ENDPOINT=http://localhost:4566 # LOCAL
# AWS_ENDPOINT=http://ministack:4566 # DOCKER
